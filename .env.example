# Copy this file to .env and fill in the values for your environment.

# Path to the trained model pickle file (relative to project root)
MODEL_PATH=models/fraud_model.pkl

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://fraud_user:changeme@localhost:5432/fraud_db

# Minimum fraud probability to flag a transaction as fraudulent (0.0 – 1.0)
FRAUD_THRESHOLD=0.5

# Uvicorn server settings
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
